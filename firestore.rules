rules_version = '2';

// All reads/writes go through the Firebase Admin SDK on the server
// (lib/firebase.ts), which bypasses these rules. This default-deny is here
// so the project fails closed if a client SDK is ever added later.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
