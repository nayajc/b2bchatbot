# Firebase Admin SDK (relational-ish data, logs — see ADR: vectors are
# in-memory for the pilot, not stored as a Firestore vector index)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the service account private key; keep the literal \n escapes —
# lib/firebase.ts converts them back to real newlines at startup.
FIREBASE_PRIVATE_KEY=

# Anthropic (generation + embeddings)
ANTHROPIC_API_KEY=
# Embedding provider: "voyage" or "anthropic" — open question, default voyage
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=

# Escalation email (Resend or SMTP)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
ESCALATION_STAFF_EMAIL=staff@example.com

# RAG tuning — set empirically via `npm run eval`, do not guess (see ADR)
RAG_SIMILARITY_THRESHOLD=0.72

# Used to build the escalation email's reply link (lib/escalation/notify.ts).
# Falls back to Vercel's auto-set VERCEL_URL, then localhost — only set this
# explicitly if you want the link to always point at your production domain.
NEXT_PUBLIC_APP_URL=https://b2bchatbot.vercel.app
